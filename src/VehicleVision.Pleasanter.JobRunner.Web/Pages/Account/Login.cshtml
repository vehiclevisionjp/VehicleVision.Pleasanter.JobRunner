@page
@model VehicleVision.Pleasanter.JobRunner.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="auth-shell">
    <div class="auth-panel">
        <h1>JobRunner</h1>
        <form method="post" class="stack">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <label asp-for="Input.LoginId"></label>
            <input asp-for="Input.LoginId" autocomplete="username" autofocus />
            <span asp-validation-for="Input.LoginId" class="field-validation"></span>

            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="field-validation"></span>

            <button type="submit" class="primary-action">Sign in</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
