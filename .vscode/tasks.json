{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/VehicleVision.Pleasanter.JobRunner.slnx"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "dotnet test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/VehicleVision.Pleasanter.JobRunner.slnx"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    }
  ]
}
